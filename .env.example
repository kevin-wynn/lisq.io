# ═══════════════════════════════════════════════════════
# LISQ Self-Host — Environment Configuration
# Save this file as .env next to your docker-compose.yml
# ═══════════════════════════════════════════════════════

# ── User Account (optional) ──
# Set both to enable login. Leave empty for open access.
LISQ_USERNAME=admin
LISQ_PASSWORD=change-me-to-a-strong-password

# ── Database ──
# Host path where the SQLite database file will be stored
# DATA_PATH=./data

# ── Server ──
# PORT=4321
